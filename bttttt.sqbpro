CREATE TABLE Books (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    title TEXT,
    author TEXT,
    category TEXT,
    quantity INTEGER
);

-- Bảng người dùng
CREATE TABLE Users (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    name TEXT,
    email TEXT UNIQUE,
    password TEXT,
    role TEXT
);

-- Bảng mượn trả
CREATE TABLE BorrowRecords (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    user_id INTEGER,
    book_id INTEGER,
    borrow_date TEXT,
    return_date TEXT,
    status TEXT,
    FOREIGN KEY(user_id) REFERENCES Users(id),
    FOREIGN KEY(book_id) REFERENCES Books(id)
);

CREATE TABLE BookDetails (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    book_id INTEGER NOT NULL,
    description TEXT,
    publish_year INTEGER,
    publisher TEXT,
    author_summary TEXT,
    FOREIGN KEY(book_id) REFERENCES Books(id)
);

CREATE TABLE BorrowDetails (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    borrow_id INTEGER NOT NULL,
    phone TEXT,
    notes TEXT,
    fine REAL DEFAULT 0,
    librarian_name TEXT,
    FOREIGN KEY(borrow_id) REFERENCES BorrowRecords(id)
);

